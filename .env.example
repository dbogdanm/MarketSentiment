# Copy this file to .env and fill in real values.
# docker-compose reads it automatically; local runs load it via python-dotenv.

# --- Flask ---
# Required in production. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- PostgreSQL ---
DB_HOST=localhost          # use "db" when running through docker-compose
DB_NAME=marketsentiment
DB_USER=user
DB_PASS=change_me

# --- Scheduler intervals (minutes) ---
PIPELINE_INTERVAL_MINUTES=25
ALERT_INTERVAL_MINUTES=5

# --- SMTP (VIX e-mail alerts; leave empty to disable) ---
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Tuning (optional) ---
GUNICORN_WORKERS=2
LOG_LEVEL=INFO
